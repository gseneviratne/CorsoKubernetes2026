{
  "title": "Pod Resources - sizing requests e limits",
  "uid": "pod-resources",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["lab", "kubernetes", "resources", "sizing"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_pod_info{namespace=~\"$namespace\"}, pod)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU usage vs request vs limit (core)",
      "description": "Linea piena = uso reale (rate). Linee tratteggiate = request e limit configurati. Se l'uso e' costantemente sopra la request, alza la request. Se e' costantemente sotto, abbassa la request. Se tocca la limit, aspettati throttling.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\"}[5m]))",
          "legendFormat": "{{pod}} - usage",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_resource_requests{namespace=~\"$namespace\",pod=~\"$pod\",resource=\"cpu\"})",
          "legendFormat": "{{pod}} - request",
          "refId": "B"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_resource_limits{namespace=~\"$namespace\",pod=~\"$pod\",resource=\"cpu\"})",
          "legendFormat": "{{pod}} - limit",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*request.*" }, "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10,10] } }, { "id": "custom.lineWidth", "value": 1 } ] },
          { "matcher": { "id": "byRegexp", "options": ".*limit.*" }, "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4,4] } }, { "id": "custom.lineWidth", "value": 1 } ] }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memoria working set vs request vs limit",
      "description": "Working set e' la memoria 'attiva' (non riclamabile). Confronta con request/limit. Sopra il limit -> OOMKill.",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\"})",
          "legendFormat": "{{pod}} - usage",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_resource_requests{namespace=~\"$namespace\",pod=~\"$pod\",resource=\"memory\"})",
          "legendFormat": "{{pod}} - request",
          "refId": "B"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_resource_limits{namespace=~\"$namespace\",pod=~\"$pod\",resource=\"memory\"})",
          "legendFormat": "{{pod}} - limit",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*request.*" }, "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10,10] } } ] },
          { "matcher": { "id": "byRegexp", "options": ".*limit.*" }, "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4,4] } } ] }
        ]
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU throttling rate (% del tempo throttled)",
      "description": "Se questo valore e' > 25% costantemente, il container e' strozzato dal CPU limit. Alza il limit o rimuovilo.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (rate(container_cpu_cfs_throttled_periods_total{namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\"}[5m])) / sum by (namespace, pod) (rate(container_cpu_cfs_periods_total{namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\"}[5m])) * 100",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 25 } ] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "OOM kills (ultime 24h)",
      "description": "Se > 0 il container ha superato il memory limit. Alza il limit oppure trova la perdita.",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 8 },
      "targets": [
        { "expr": "sum(increase(kube_pod_container_status_last_terminated_reason{reason=\"OOMKilled\"}[24h])) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Container restart rate /h",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 8 },
      "targets": [
        { "expr": "sum(rate(kube_pod_container_status_restarts_total{namespace=~\"$namespace\",pod=~\"$pod\"}[5m])) * 3600", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Pod sotto-dimensionati (CPU usage > 80% del request)",
      "description": "Candidati ad alzare la CPU request. La query filtra solo i pod con request > 0.",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "(sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) / sum by (namespace, pod) (kube_pod_container_resource_requests{resource=\"cpu\"} > 0)) > 0.8",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "usage / request" } } }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Pod sovra-dimensionati (CPU usage < 20% del request)",
      "description": "Candidati ad abbassare la CPU request per liberare capacita' del cluster.",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "(sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) / sum by (namespace, pod) (kube_pod_container_resource_requests{resource=\"cpu\"} > 0)) < 0.2",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "usage / request" } } }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Memoria - usage vs request (snapshot)",
      "description": "Se 'usage / request' e' >> 1 alza la memory request. Se < 0.3 abbassala.",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (container_memory_working_set_bytes{container!=\"\"}) / sum by (namespace, pod) (kube_pod_container_resource_requests{resource=\"memory\"} > 0)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null }, { "color": "green", "value": 0.3 }, { "color": "yellow", "value": 0.8 }, { "color": "red", "value": 1.0 } ] } } },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "usage / request" } } }
      ]
    }
  ]
}
